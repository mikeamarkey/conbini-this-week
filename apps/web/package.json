{
  "name": "conbini-this-week-web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "checks": "pnpm /checks:.*/",
    "checks:lint": "eslint . --ext ts --ext tsx --ext js",
    "checks:prettier": "prettier --check .",
    "checks:tsc": "tsc --pretty --noEmit",
    "fix": "pnpm /fix:.*/",
    "fix:lint": "pnpm checks:lint --fix",
    "fix:prettier": "prettier --write .",
    "staged": "lint-staged --allow-empty",
    "start": "next start",
    "test": "jest"
  },
  "dependencies": {
    "next": "13.1.6",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-use": "17.4.0"
  },
  "devDependencies": {
    "@types/node": "20.11.30",
    "@types/react": "18.2.73",
    "@typescript-eslint/eslint-plugin": "7.4.0",
    "@typescript-eslint/parser": "7.4.0",
    "autoprefixer": "^10.4.13",
    "eslint": "8.57.0",
    "eslint-config-next": "14.1.4",
    "eslint-config-prettier": "9.1.0",
    "postcss": "^8.4.21",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "tailwindcss": "^3.2.7",
    "typescript": "5.4.3"
  }
}
